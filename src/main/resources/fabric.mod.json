{
  "schemaVersion": 1,
  "id": "pvptoggle",
  "version": "${version}",
  "name": "pvpToggle",
  "description": "Opt-in PvP flagging system. Only players flagged for PvP can deal and take damage from each other.",
  "authors": ["LunixiaLIVE"],
  "contact": {
    "sources": "https://github.com/LunixiaLIVE/pvpToggle"
  },
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": [
      "net.lunix.pvptoggle.PvpToggle"
    ]
  },
  "mixins": [
    "pvptoggle.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
